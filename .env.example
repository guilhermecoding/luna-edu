# Nome da corporação
NEXT_PUBLIC_NAME_CORPORATION=

# URL do logo da corporação
NEXT_PUBLIC_LOGO_CORPORATION=

# URL do banco de dados
DATABASE_URL=""

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
BETTER_AUTH_TRUSTED_ORIGINS=

# Origens extras no dev (allowedDevOrigins): hosts separados por vírgula, ex. 192.168.0.10,192.168.0.10:3000 ou http://192.168.0.10:3000
# Preferível sem NEXT_PUBLIC (não é variável de cliente). next.config carrega .env antes de ler.
ALLOWED_DEV_ORIGINS=
NEXT_PUBLIC_ALLOWED_DEV_ORIGINS=

# Modo de build - production ou development ou undefined
NEXT_PUBLIC_BUILD_MODE