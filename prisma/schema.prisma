generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["better_auth", "public"]
}

model User {
  id               String            @id
  name             String
  email            String            @unique
  emailVerified    Boolean           @default(false) @map("email_verified")
  image            String?
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  cpf              String            @unique
  phone            String
  birthDate        DateTime          @map("birth_date") @db.Date
  bio              String?
  isAdmin          Boolean           @default(false) @map("is_admin")
  isTeacher        Boolean           @default(false) @map("is_teacher")
  isActive         Boolean           @default(true) @map("is_active")
  lunaId           String?           @unique @map("luna_id")
  banExpires       DateTime?
  banReason        String?
  banned           Boolean?          @default(false)
  role             String?
  systemRole       SystemRole        @default(FULL_ACCESS) @map("system_role")
  genre            UserGenre         @default(PREFER_NOT_TO_SAY)
  accounts         Account[]
  sessions         Session[]
  courseAssistants CourseAssistant[]
  lessons          Lesson[]
  notifications    Notification[]
  schedules        Schedule[]

  @@map("user")
  @@schema("better_auth")
}

model Session {
  id             String   @id
  expiresAt      DateTime @map("expires_at")
  token          String   @unique
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  userId         String   @map("user_id")
  impersonatedBy String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
  @@schema("better_auth")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
  @@schema("better_auth")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([identifier])
  @@map("verification")
  @@schema("better_auth")
}

model Program {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  name        String
  description String?
  slug        String     @unique
  degrees     Degree[]
  periods     Period[]
  timeSlots   TimeSlot[]

  @@map("programs")
  @@schema("public")
}

model Degree {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  name             String
  slug             String
  description      String?
  modality         String?
  level            String?
  totalHours       Int?         @map("total_hours")
  /// JSON map of basePeriod number -> display label.
  /// Ex: {"1": "1º Ano", "2": "2º Ano", "3": "3º Ano"}
  gradeLevelLabels Json?        @map("grade_level_labels")
  programId        String       @map("program_id") @db.Uuid
  classGroups      ClassGroup[]
  program          Program      @relation(fields: [programId], references: [id])
  subjects         Subject[]

  @@unique([programId, slug])
  @@map("degrees")
  @@schema("public")
}

model Subject {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  name       String
  code       String   @unique
  workload   Int?
  basePeriod Int?     @map("base_period") @db.SmallInt
  degreeId   String   @map("degree_id") @db.Uuid
  courses    Course[]
  degree     Degree   @relation(fields: [degreeId], references: [id])

  @@map("subjects")
  @@schema("public")
}

model Campus {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  address   String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  rooms     Room[]

  @@map("campuses")
  @@schema("public")
}

model Room {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  name      String
  capacity  BigInt
  block     String?
  type      RoomType   @default(CLASSROOM)
  campusId  String     @map("campus_id") @db.Uuid
  slug      String
  courses   Course[]
  campus    Campus     @relation(fields: [campusId], references: [id])
  schedules Schedule[]

  @@unique([campusId, slug])
  @@map("rooms")
  @@schema("public")
}

model Period {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  name           String
  startDate      DateTime        @map("start_date") @db.Date
  endDate        DateTime        @map("end_date") @db.Date
  programId      String          @map("id_program") @db.Uuid
  completedAt    DateTime?       @map("completed_at") @db.Timestamptz(6)
  slug           String
  canonicalCode  String?         @unique @default(dbgenerated("gen_random_uuid()")) @map("canonical_code") @db.Uuid
  classGroups    ClassGroup[]
  courses        Course[]
  program        Program         @relation(fields: [programId], references: [id])
  studentPeriods StudentPeriod[]
  subPeriods     SubPeriod[]

  @@unique([programId, slug])
  @@index([programId, completedAt, startDate, endDate])
  @@map("periods")
  @@schema("public")
}

model SubPeriod {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  name       String
  slug       String
  order      Int        @db.SmallInt
  startDate  DateTime   @map("start_date") @db.Date
  endDate    DateTime   @map("end_date") @db.Date
  weight     Float      @default(1.0)
  closedAt   DateTime?  @map("closed_at") @db.Timestamptz(6)
  periodId   String     @map("period_id") @db.Uuid
  activities Activity[]
  period     Period     @relation(fields: [periodId], references: [id])

  @@unique([periodId, slug])
  @@unique([periodId, order])
  @@map("sub_periods")
  @@schema("public")
}

model ClassGroup {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  name       String
  slug       String
  periodId   String   @map("period_id") @db.Uuid
  degreeId   String   @map("degree_id") @db.Uuid
  basePeriod Int      @map("base_period") @db.SmallInt
  shift      Shift
  groupLink  String?  @map("group_link")
  degree     Degree   @relation(fields: [degreeId], references: [id])
  period     Period   @relation(fields: [periodId], references: [id])
  courses    Course[]

  @@unique([periodId, slug])
  @@map("class_groups")
  @@schema("public")
}

model TimeSlot {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  startTime String     @map("start_time")
  endTime   String     @map("end_time")
  shift     Shift
  programId String     @map("program_id") @db.Uuid
  lessons   Lesson[]
  schedules Schedule[]
  program   Program    @relation(fields: [programId], references: [id])

  @@unique([programId, startTime])
  @@map("time_slots")
  @@schema("public")
}

model Schedule {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  courseId   String    @map("course_id") @db.Uuid
  dayOfWeek  DayOfWeek @map("day_of_week")
  timeSlotId String    @map("time_slot_id") @db.Uuid
  teacherId  String?   @map("teacher_id")
  roomId     String?   @map("room_id") @db.Uuid
  lessons    Lesson[]
  course     Course    @relation(fields: [courseId], references: [id])
  room       Room?     @relation(fields: [roomId], references: [id])
  teacher    User?     @relation(fields: [teacherId], references: [id])
  timeSlot   TimeSlot  @relation(fields: [timeSlotId], references: [id])

  @@unique([courseId, dayOfWeek, timeSlotId])
  @@unique([teacherId, dayOfWeek, timeSlotId])
  @@unique([roomId, dayOfWeek, timeSlotId])
  @@map("schedules")
  @@schema("public")
}

model Course {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  name             String
  code             String
  periodId         String               @map("period_id") @db.Uuid
  roomId           String?              @map("room_id") @db.Uuid
  subjectId        String               @map("subject_id") @db.Uuid
  shift            Shift
  classGroupId     String?              @map("class_group_id") @db.Uuid
  activities       Activity[]
  courseAssistants CourseAssistant[]
  classGroup       ClassGroup?          @relation(fields: [classGroupId], references: [id])
  period           Period               @relation(fields: [periodId], references: [id])
  room             Room?                @relation(fields: [roomId], references: [id])
  subject          Subject              @relation(fields: [subjectId], references: [id])
  enrollments      Enrollment[]
  finalGrades      FinalGrade[]
  lessons          Lesson[]
  schedules        Schedule[]
  stats            StudentCourseStats[]

  @@unique([periodId, code])
  @@map("courses")
  @@schema("public")
}

model Student {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  name           String
  birthDate      DateTime             @map("birth_date") @db.Date
  studentPhone   String               @map("student_phone")
  parentPhone    String?              @map("parent_phone")
  cpf            String               @unique
  email          String
  school         String
  genre          Genre
  lunaId         String?              @unique @map("luna_id")
  activityGrades ActivityGrade[]
  attendances    Attendance[]
  enrollments    Enrollment[]
  finalGrades    FinalGrade[]
  notifications  Notification[]
  stats          StudentCourseStats[]
  studentPeriods StudentPeriod[]

  @@map("students")
  @@schema("public")
}

model Enrollment {
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  courseId  String   @map("course_id") @db.Uuid
  studentId String   @map("student_id") @db.Uuid
  course    Course   @relation(fields: [courseId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@id([courseId, studentId])
  @@map("enrollments")
  @@schema("public")
}

model StudentPeriod {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId  String    @map("student_id") @db.Uuid
  periodId   String    @map("period_id") @db.Uuid
  status     String    @default("WAITING")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  accessedAt DateTime? @map("accessed_at") @db.Timestamptz(6)
  period     Period    @relation(fields: [periodId], references: [id], onDelete: Cascade)
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, periodId])
  @@map("student_periods")
  @@schema("public")
}

model Lesson {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  courseId    String       @map("course_id") @db.Uuid
  date        DateTime     @db.Date
  topic       String
  scheduleId  String?      @map("schedule_id") @db.Uuid
  timeSlotId  String?      @map("time_slot_id") @db.Uuid
  teacherId   String?      @map("teacher_id")
  attendances Attendance[]
  course      Course       @relation(fields: [courseId], references: [id])
  schedule    Schedule?    @relation(fields: [scheduleId], references: [id])
  teacher     User?        @relation(fields: [teacherId], references: [id])
  timeSlot    TimeSlot?    @relation(fields: [timeSlotId], references: [id])

  @@map("lessons")
  @@schema("public")
}

model Attendance {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lessonId    String   @map("lesson_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  isPresent   Boolean  @default(false) @map("is_present")
  observation String?
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id])

  @@map("attendances")
  @@schema("public")
}

model Activity {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  courseId       String          @map("course_id") @db.Uuid
  subPeriodId    String?         @map("sub_period_id") @db.Uuid
  title          String
  gradingType    GradingType     @default(NONE) @map("grading_type")
  minValue       Float?          @map("min_value")
  maxValue       Float?          @map("max_value")
  type           ActivityType    @default(HOMEWORK)
  weight         Float           @default(1.0)
  dueDate        DateTime?       @map("due_date") @db.Timestamptz(6)
  course         Course          @relation(fields: [courseId], references: [id])
  subPeriod      SubPeriod?      @relation(fields: [subPeriodId], references: [id])
  activityGrades ActivityGrade[]

  @@map("activities")
  @@schema("public")
}

model ActivityGrade {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  activityId   String   @map("activity_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  earnedPoints Float?   @map("earned_points")
  earnedHits   Float?   @map("earned_hits")
  activity     Activity @relation(fields: [activityId], references: [id])
  student      Student  @relation(fields: [studentId], references: [id])

  @@map("activity_grades")
  @@schema("public")
}

model FinalGrade {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  courseId   String   @map("course_id") @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  average    Float?
  concept    String?
  isApproved Boolean? @map("is_approved")
  course     Course   @relation(fields: [courseId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id])

  @@unique([courseId, studentId])
  @@map("final_grades")
  @@schema("public")
}

model StudentCourseStats {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  courseId       String   @map("course_id") @db.Uuid
  studentId      String   @map("student_id") @db.Uuid
  attendanceRate Float?   @map("attendance_rate")
  averageGrade   Float?   @map("average_grade")
  totalLessons   Int?     @map("total_lessons")
  presentCount   Int?     @map("present_count")
  course         Course   @relation(fields: [courseId], references: [id])
  student        Student  @relation(fields: [studentId], references: [id])

  @@unique([courseId, studentId])
  @@map("student_course_stats")
  @@schema("public")
}

model Notification {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  title     String
  message   String
  type      NotificationType @default(INFO)
  userId    String?          @map("user_id")
  studentId String?          @map("student_id") @db.Uuid
  isRead    Boolean          @default(false) @map("is_read")
  student   Student?         @relation(fields: [studentId], references: [id])
  user      User?            @relation(fields: [userId], references: [id])

  @@map("notifications")
  @@schema("public")
}

model CourseAssistant {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  courseId    String   @map("course_id") @db.Uuid
  assistantId String   @map("assistant_id")
  assistant   User     @relation(fields: [assistantId], references: [id])
  course      Course   @relation(fields: [courseId], references: [id])

  @@map("course_assistants")
  @@schema("public")
}

enum Genre {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY

  @@map("genre")
  @@schema("public")
}

enum GradingType {
  NONE
  POINTS
  HITS

  @@map("grading_type")
  @@schema("public")
}

enum Shift {
  MORNING
  AFTERNOON
  EVENING

  @@map("shift")
  @@schema("public")
}

enum ActivityType {
  HOMEWORK
  EXAM
  PROJECT
  QUIZ
  PARTICIPATION

  @@map("activity_type")
  @@schema("public")
}

enum RoomType {
  CLASSROOM
  LABORATORY
  AUDITORIUM
  OTHERS

  @@map("room_type")
  @@schema("public")
}

enum NotificationType {
  INFO
  WARNING
  ALERT

  @@map("notification_type")
  @@schema("public")
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY

  @@map("day_of_week")
  @@schema("public")
}

enum SystemRole {
  FULL_ACCESS
  READ_ONLY

  @@map("system_role")
  @@schema("better_auth")
}

enum UserGenre {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY

  @@map("user_genre")
  @@schema("better_auth")
}
